resultLabel.Position = UDim2.new(0, 0, 0.7, 0)
resultLabel.BackgroundTransparency = 1
resultLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
resultLabel.Text = "Result: "
resultLabel.Font = Enum.Font.GothamBold
resultLabel.TextSize = 14
resultLabel.Parent = contentFrame

-- Buttons
local operations = {"+", "-", "×", "÷", "="}
local buttons = {}
for i, symbol in ipairs(operations) do
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.14, 0, 0, 30)
	btn.Position = UDim2.new(0.1 + (i-1)*0.18, 0, 0.48, 0)
	btn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Text = symbol
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 16
	btn.Parent = contentFrame

	local bcorner = Instance.new("UICorner")
	bcorner.CornerRadius = UDim.new(0, 6)
	bcorner.Parent = btn

	buttons[symbol] = btn
end

-- Calculator logic
local currentOp = nil
for symbol, btn in pairs(buttons) do
	btn.MouseButton1Click:Connect(function()
		local num1 = tonumber(box1.Text)
		local num2 = tonumber(box2.Text)
		if symbol ~= "=" then
			currentOp = symbol
			resultLabel.Text = "Selected: " .. symbol
			return
		end
		if num1 and num2 and currentOp then
			local res
			if currentOp == "+" then res = num1 + num2
			elseif currentOp == "-" then res = num1 - num2
			elseif currentOp == "×" then res = num1 * num2
			elseif currentOp == "÷" then res = num2 ~= 0 and num1 / num2 or "∞" end
			resultLabel.Text = "Result: " .. tostring(res)
		else
			resultLabel.Text = "⚠️ Enter valid numbers!"
		end
	end)
end

-- Minimize logic
local isMinimized = false
minimizeButton.MouseButton1Click:Connect(function()
	isMinimized = not isMinimized
	contentFrame.Visible = not isMinimized
	mainFrame.Size = isMinimized and UDim2.new(0, 250, 0, 30) or UDim2.new(0, 250, 0, 230)
	minimizeButton.Text = isMinimized and "👆" or "👇"
end)

